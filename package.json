{
  "name": "@oasisbio/oasiswaker",
  "version": "1.0.0",
  "description": "CLI tool for contributing Cloudflare, Vercel, and Supabase resources to OasisBio's decentralized network",
  "type": "module",
  "bin": {
    "oasiswaker": "./dist/cli/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src --ext .ts"
  },
  "keywords": ["oasisbio", "decentralized", "cloudflare", "vercel", "supabase", "serverless"],
  "author": "OasisBio",
  "license": "MIT",
  "dependencies": {
    "commander": "^12.1.0",
    "inquirer": "^9.2.23",
    "open": "^10.1.0",
    "chalk": "^5.3.0",
    "ora": "^8.1.0",
    "axios": "^1.7.7",
    "zod": "^3.23.8",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.7.9",
    "@types/inquirer": "^9.0.7",
    "@types/uuid": "^10.0.0",
    "typescript": "^5.6.3",
    "vitest": "^2.1.3",
    "@vitest/coverage-v8": "^2.1.3",
    "eslint": "^9.13.0",
    "@typescript-eslint/eslint-plugin": "^8.11.0",
    "@typescript-eslint/parser": "^8.11.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
