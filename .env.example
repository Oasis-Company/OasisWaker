# OasisWaker Environment Variables

# Cloudflare OAuth Configuration
CLOUDFLARE_CLIENT_ID=oasiswaker-cli
CLOUDFLARE_REDIRECT_URI=http://localhost:3000/callback

# Vercel OAuth Configuration
VERCELL_CLIENT_ID=oasiswaker-cli
VERCELL_REDIRECT_URI=http://localhost:3000/callback

# Supabase OAuth Configuration
SUPABASE_CLIENT_ID=oasiswaker-cli
SUPABASE_REDIRECT_URI=http://localhost:3000/callback

# OasisBio API Configuration
OASISBIO_API_ENDPOINT=https://oasisbio.com
